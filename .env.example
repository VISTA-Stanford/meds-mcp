# meds-mcp environment variables
# ---------------------------------------------------------------
# Copy this file to .env and fill in real values.
# .env is gitignored; only .env.example is tracked.
# Auto-loaded by experiments/fewshot_with_labels/_paths.py on import,
# so every script in that experiment picks these up without flags.
# Any var already set in the shell wins over this file.

# ---------------------------------------------------------------
# fewshot_with_labels experiment paths
# ---------------------------------------------------------------
# On your local laptop: leave these blank — the code falls back to
# the repo-relative defaults under data/collections/vista_bench/.
#
# On a GCP VM: do NOT edit these by hand. Run the setup script once:
#     bash scripts/setup_vm.sh --copy-gcs
# It will download data from GCS to local disk and overwrite this
# file with the correct paths. You only need to paste VAULT_SECRET_KEY
# afterward.
VISTA_COHORT_CSV=
VISTA_CORPUS_DIR=
VISTA_OUTPUTS_DIR=

# ---------------------------------------------------------------
# Secrets
# ---------------------------------------------------------------
# REQUIRED for any secure-llm model call (apim:gpt-4.1-mini, etc.).
# Obtain from the secure-llm team.
VAULT_SECRET_KEY=

# ---------------------------------------------------------------
# Other env vars used elsewhere in the repo (uncomment if needed)
# ---------------------------------------------------------------
# DATA_DIR=/path/to/corpus
# CACHE_DIR=/path/to/cache
# VISTA_LABELS_DIR=data/collections/vista_bench/labels
# LOAD_ALL_PATIENTS=false
