# meds-mcp environment variables
# ---------------------------------------------------------------
# Copy this file to .env and fill in real values.
# .env is gitignored; only .env.example is tracked.
# Auto-loaded by experiments/fewshot_with_labels/_paths.py on import,
# so every script in that experiment picks these up without flags.
# Any var already set in the shell wins over this file.

# --- fewshot_with_labels experiment paths ---
# Local defaults in the repo work unchanged if these are blank.
# Set these on a GCP VM (or any other environment) where the data
# lives somewhere other than the repo's data/ tree.
VISTA_COHORT_CSV=/path/to/su_vista_scratch/bikia_dev/lumia_cohort_progression_tasks-000000000000.csv
VISTA_CORPUS_DIR=/path/to/vista_bench/thoracic_cohort_lumia
VISTA_OUTPUTS_DIR=/path/to/fewshot_with_labels_outputs

# --- secure-llm / Vault ---
# Required for apim:gpt-4.1-mini and any other Stanford secure-llm models.
# Reach out to the secure-llm team for a personal key.
VAULT_SECRET_KEY=

# --- Other env vars used elsewhere in the repo (uncomment if needed) ---
# DATA_DIR=/path/to/corpus
# CACHE_DIR=/path/to/cache
# VISTA_LABELS_DIR=data/collections/vista_bench/labels
# LOAD_ALL_PATIENTS=false
